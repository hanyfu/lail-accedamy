    "db:restore": "bash ./scripts/db-restore.sh"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "prisma": "^5.22.0",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": "20.11.1"
  },
  "packageManager": "npm@10.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
