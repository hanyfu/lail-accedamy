// Lail Academy — Admissions and Finance Management System
// Prisma Schema — PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────

enum UserRole {
  ADMIN
  APPLICANT
  STUDENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ApplicantStatus {
  PENDING
  APPROVED
  REJECTED
}

enum IntakeStatus {
  ACTIVE
  CLOSED
}

enum InvoiceStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum PaymentStatus {
  SUBMITTED
  VERIFIED
  REJECTED
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  STUDYING
  COMPLETED
  DROPOUT
  REJECTED
}

enum EnrollmentSex {
  MALE
  FEMALE
  OTHER
}

enum NoticeAudience {
  ALL
  APPLICANTS
  STUDENTS
}

enum DownloadCategory {
  ADMISSION
  ACADEMIC
  POLICY
  FORM
  OTHER
}

enum ClassAvailability {
  OPEN
  LIMITED
  FULL
  CLOSED
}

// ─── Models ─────────────────────────────────────────────

model User {
  id               Int        @id @default(autoincrement())
  email            String     @unique
  name             String?
  password         String
  role             UserRole   @default(APPLICANT)
  status           UserStatus @default(ACTIVE)
  refreshToken     String?
  resetToken       String?
  resetTokenExpiry DateTime?
  applicant        Applicant?
  student          Student?
  auditLogs        AuditLog[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([email])
  @@index([role])
  @@map("users")
}

model Department {
  id        Int       @id @default(autoincrement())
  name      String
  code      String    @unique
  programs  Program[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([code])
  @@index([name])
  @@map("departments")
}

model Program {
  id            Int            @id @default(autoincrement())
  name          String
  code          String         @unique
  description   String?
  duration      String? // e.g. "4 years"
  departmentId  Int
  department    Department     @relation(fields: [departmentId], references: [id])
  intakes       Intake[]
  applicants    Applicant[]
  feeStructures FeeStructure[]
  notices       Notice[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([code])
  @@index([name])
  @@index([departmentId])
  @@map("programs")
}

model Intake {
  id                  Int            @id @default(autoincrement())
  name                String // e.g. "Fall 2026"
  programId           Int
  program             Program        @relation(fields: [programId], references: [id])
  startDate           DateTime
  endDate             DateTime
  applicationDeadline DateTime
  maxCapacity         Int            @default(100)
  status              IntakeStatus   @default(ACTIVE)
  applicants          Applicant[]
  feeStructures       FeeStructure[]
  notices             Notice[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([programId])
  @@index([status])
  @@index([name])
  @@map("intakes")
}

model Applicant {
  id            Int             @id @default(autoincrement())
  firstName     String
  lastName      String
  email         String
  phone         String
  dateOfBirth   DateTime?
  address       String?
  nationality   String?
  previousEdu   String? // Previous education details
  intakeId      Int
  intake        Intake          @relation(fields: [intakeId], references: [id])
  programId     Int
  program       Program         @relation(fields: [programId], references: [id])
  status        ApplicantStatus @default(PENDING)
  rejectionNote String?
  submittedAt   DateTime        @default(now())
  student       Student?
  userId        Int?            @unique
  user          User?           @relation(fields: [userId], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([email])
  @@index([phone])
  @@index([lastName])
  @@index([intakeId])
  @@index([programId])
  @@index([status])
  @@map("applicants")
}

model Student {
  id          Int       @id @default(autoincrement())
  studentId   String    @unique // e.g. "STU-2026-001"
  applicantId Int       @unique
  applicant   Applicant @relation(fields: [applicantId], references: [id])
  userId      Int       @unique
  user        User      @relation(fields: [userId], references: [id])
  enrolledAt  DateTime  @default(now())
  invoices    Invoice[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([studentId])
  @@index([applicantId])
  @@index([userId])
  @@map("students")
}

model FeeStructure {
  id        Int       @id @default(autoincrement())
  name      String // e.g. "Tuition Fee", "Registration Fee"
  amount    Float
  currency  String    @default("MVR")
  programId Int
  program   Program   @relation(fields: [programId], references: [id])
  intakeId  Int?
  intake    Intake?   @relation(fields: [intakeId], references: [id])
  invoices  Invoice[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([programId])
  @@index([intakeId])
  @@index([name])
  @@map("fee_structures")
}

model Invoice {
  id             Int           @id @default(autoincrement())
  invoiceNumber  String        @unique // e.g. "INV-2026-001"
  studentId      Int
  student        Student       @relation(fields: [studentId], references: [id])
  feeStructureId Int
  feeStructure   FeeStructure  @relation(fields: [feeStructureId], references: [id])
  amount         Float
  paidAmount     Float         @default(0)
  dueDate        DateTime
  status         InvoiceStatus @default(PENDING)
  payments       Payment[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([studentId])
  @@index([feeStructureId])
  @@index([status])
  @@index([invoiceNumber])
  @@map("invoices")
}

model Payment {
  id           Int           @id @default(autoincrement())
  invoiceId    Int?
  invoice      Invoice?      @relation(fields: [invoiceId], references: [id])
  enrollmentId Int?
  enrollment   Enrollment?   @relation(fields: [enrollmentId], references: [id])
  amount       Float
  method       String // e.g. "BANK_TRANSFER", "CASH", "CARD"
  proofUrl     String? // File path to payment proof
  reference    String? // Transaction reference
  status       PaymentStatus @default(SUBMITTED)
  notes        String? // Admin notes on verification
  verifiedAt   DateTime?
  paymentDate  DateTime      @default(now())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([invoiceId])
  @@index([enrollmentId])
  @@index([status])
  @@index([reference])
  @@map("payments")
}

model Notice {
  id          Int            @id @default(autoincrement())
  title       String
  content     String
  audience    NoticeAudience @default(ALL)
  programId   Int?
  program     Program?       @relation(fields: [programId], references: [id])
  intakeId    Int?
  intake      Intake?        @relation(fields: [intakeId], references: [id])
  isPublished Boolean        @default(true)
  expiryDate  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([audience])
  @@index([programId])
  @@index([intakeId])
  @@index([isPublished])
  @@index([title])
  @@map("notices")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  action    String // e.g. "CREATE", "UPDATE", "DELETE", "APPROVE", "REJECT"
  entity    String // e.g. "Applicant", "Invoice", "Payment"
  entityId  String
  details   String? // JSON string with details
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Course {
  id           Int               @id @default(autoincrement())
  title        String
  code         String            @unique
  description  String?
  duration     String?
  slots        Int               @default(0)
  monthlyFee   Float             @default(0)
  availability ClassAvailability @default(OPEN)
  isActive     Boolean           @default(true)
  enrollments  Enrollment[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([title])
  @@index([code])
  @@index([availability])
  @@index([slots])
  @@index([monthlyFee])
  @@index([isActive])
  @@map("courses")
}

model GalleryImage {
  id        Int      @id @default(autoincrement())
  imageUrl  String
  caption   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([caption])
  @@map("gallery_images")
}

model DownloadItem {
  id        Int              @id @default(autoincrement())
  title     String
  category  DownloadCategory @default(OTHER)
  fileUrl   String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([title])
  @@index([category])
  @@index([createdAt])
  @@map("downloads")
}

model Announcement {
  id        Int      @id @default(autoincrement())
  isEnabled Boolean  @default(false)
  text      String?
  link      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("announcements")
}

model Enrollment {
  id               Int              @id @default(autoincrement())
  parentName       String?
  fullName         String
  sex              EnrollmentSex?
  birthDate        DateTime?
  email            String
  phone            String
  viberPhone       String?
  address          String?
  telegramId       String?
  message          String?
  status           EnrollmentStatus @default(PENDING)
  rejectionNote    String?
  idCardNo         String?          @unique
  classFee         Float            @default(0) // Monthly fee
  totalBilled      Float            @default(0)
  totalPaid        Float            @default(0)
  billingStartDate DateTime?
  billingStoppedAt DateTime?
  isArchived       Boolean          @default(false)
  archivedAt       DateTime?
  approvedAt       DateTime?
  startedAt        DateTime?
  courseId         Int?
  course           Course?          @relation(fields: [courseId], references: [id])
  payments         Payment[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([fullName])
  @@index([parentName])
  @@index([email])
  @@index([phone])
  @@index([viberPhone])
  @@index([courseId])
  @@index([status])
  @@index([isArchived])
  @@index([billingStartDate])
  @@index([sex])
  @@index([idCardNo])
  @@index([createdAt])
  @@map("enrollments")
}

model PageSection {
  id         Int      @id @default(autoincrement())
  pageKey    String
  sectionKey String
  fields     Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([pageKey, sectionKey])
  @@index([pageKey])
  @@index([sectionKey])
  @@map("page_sections")
}

model SiteSetting {
  id          Int      @id @default(autoincrement())
  collegeName String?
  tagline     String?
  logoUrl     String?
  phone       String?
  email       String?
  address     String?
  mapUrl      String?
  footerText  String?
  homeContent Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("site_settings")
}
